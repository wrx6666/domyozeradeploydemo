---
import "../styles/global.css";
import BookingModal from "../components/BookingModal.astro";
import { fallbackEvents } from "../data/events";

const assetBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const asset = (path: string) => `${assetBase}${path.replace(/^\//, "")}`;
const home = assetBase;
const eventsFeedUrl = import.meta.env.PUBLIC_EVENTS_SHEET_CSV_URL || "";
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Афиша | Моё Прибайкалье</title>
  </head>
  <body>
    <header class="history-page-header services-page-header">
      <a class="logo" href={home} aria-label="Моё Прибайкалье">
        <span class="logo-image" aria-hidden="true"></span>
      </a>

      <nav class="nav" aria-label="Навигация по сайту">
        <a href={`${home}#about`}>О месте</a>
        <a href={asset("/services")}>Услуги</a>
        <a href={asset("/menu")}>Кафе</a>
        <a href={asset("/history")}>История</a>
        <a class="is-active" href={asset("/events")}>Афиша</a>
        <a href={asset("/press")}>Пресса о нас</a>
        <a href={`${home}#gallery`}>Галерея</a>
        <a href={`${home}#contacts`}>Контакты</a>
      </nav>

      <div class="header-actions">
        <a class="booking-button" href={`${home}#booking`}>Забронировать</a>
        <button class="menu-button" type="button" aria-label="Открыть меню" aria-expanded="false" data-menu-open>
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <main class="events-page">
      <section class="events-page-hero">
        <div class="events-page-hero__copy">
          <p class="section-kicker">Афиша</p>
          <h1>Афиша событий</h1>
          <p>
            Ближайшие встречи, экскурсии и сезонные программы у Байкала.
            Выбирайте событие, смотрите подробности и переходите к записи.
          </p>
          <a class="button button-primary" href="#schedule">Смотреть события</a>
        </div>
        <div class="events-page-hero__media" aria-label="Байкал и территория комплекса"></div>
      </section>

      <section class="events-schedule" id="schedule">
        <div class="events-mode-bar" aria-label="Раздел афиши">
          <span class="is-active">Все события</span>
        </div>

        <div class="events-schedule__heading">
          <div>
            <p class="section-kicker">Расписание</p>
            <h2>Все события</h2>
          </div>
        </div>

        <div
          class="events-schedule__grid"
          data-events-feed="page"
          data-events-url={eventsFeedUrl}
          data-asset-base={assetBase}
          data-events-fallback="page-events-fallback"
        >
          {fallbackEvents.map((event, index) => {
            const date = new Date(`${event.date}T00:00:00`);
            const day = String(date.getDate()).padStart(2, "0");
            const month = date.toLocaleString("ru-RU", { month: "long" });

            return (
              <article class:list={["events-schedule-card", index === 0 && "events-schedule-card--featured"]} id={event.id}>
                <div class="events-schedule-card__image" style={`background-image: url('${asset(event.image)}')`}>
                  <time datetime={event.date}><b>{day}</b><span>{month}</span></time>
                </div>
                <div class="events-schedule-card__body">
                  <span class="tag">{event.type}</span>
                  <h3>{event.title}</h3>
                  <p>{event.text}</p>
                  <div class="event-time"><span aria-hidden="true"></span>{event.time}</div>
                  <a href={event.url || `${home}#booking`} target={event.url ? "_blank" : undefined} rel={event.url ? "noreferrer" : undefined}>Подробнее <span aria-hidden="true">→</span></a>
                </div>
              </article>
            );
          })}
        </div>

        <script id="page-events-fallback" type="application/json" set:html={JSON.stringify(fallbackEvents)}></script>
      </section>
    </main>

    <footer class="footer" id="contacts">
      <div class="footer-grid">
        <div class="footer-brand">
          <a class="logo" href={home} aria-label="Моё Прибайкалье">
            <span class="logo-image" aria-hidden="true"></span>
          </a>

          <address class="contacts-list">
            <a href="https://yandex.ru/maps/?text=%D1%83%D0%BB.%20%D0%91%D0%B5%D1%80%D0%B5%D0%B3%D0%BE%D0%B2%D0%B0%D1%8F%202%D0%91%2C%20%D1%81%D0%B5%D0%BB%D0%BE%20%D0%93%D1%80%D0%B5%D0%BC%D1%8F%D1%87%D0%B8%D0%BD%D1%81%D0%BA%2C%20%D0%9F%D1%80%D0%B8%D0%B1%D0%B0%D0%B9%D0%BA%D0%B0%D0%BB%D1%8C%D1%81%D0%BA%D0%B8%D0%B9%20%D1%80%D0%B0%D0%B9%D0%BE%D0%BD%2C%20%D0%A0%D0%B5%D1%81%D0%BF%D1%83%D0%B1%D0%BB%D0%B8%D0%BA%D0%B0%20%D0%91%D1%83%D1%80%D1%8F%D1%82%D0%B8%D1%8F" target="_blank" rel="noreferrer">
              <span aria-hidden="true">⌖</span>
              ул. Береговая 2Б,<br />село Гремячинск,<br />Прибайкальский район,<br />Республика Бурятия
            </a>
            <a href="tel:+79247761161">
              <span aria-hidden="true">☎</span>
              +7 (924) 776-1161
            </a>
            <a href="mailto:brcbs@bk.ru">
              <span aria-hidden="true">✉</span>
              brcbs@bk.ru
            </a>
          </address>
        </div>

        <nav class="footer-nav" aria-label="Навигация в подвале">
          <div>
            <a class="footer-nav-title" href={`${home}#about`}>О месте</a>
            <a href={`${home}#about`}>Команда</a>
            <a href={`${home}#about`}>Документы</a>
          </div>
          <div>
            <a class="footer-nav-title" href={asset("/services")}>Услуги</a>
            <a href={asset("/services#stay")}>Проживание</a>
            <a href={asset("/services#bath")}>Бани</a>
            <a href={asset("/services#food")}>Питание</a>
          </div>
          <div>
            <a class="footer-nav-title" href={asset("/history")}>История</a>
            <a href={asset("/history#chronicle")}>Фотохроника</a>
            <a href={asset("/history#people")}>Люди и традиции</a>
          </div>
          <div>
            <a class="footer-nav-title" href={asset("/press")}>Пресса о нас</a>
            <a href={asset("/press#news")}>Новости</a>
            <a href={asset("/press#publications")}>Публикации</a>
            <a href={asset("/press#media")}>СМИ о нас</a>
          </div>
          <div>
            <a class="footer-nav-title" href={`${home}#gallery`}>Фотогалерея</a>
            <a href={`${home}#gallery`}>Природа Байкала</a>
            <a href={`${home}#gallery`}>Времена года</a>
          </div>
          <div>
            <a class="footer-nav-title" href="#contacts">Контакты</a>
            <a href="https://yandex.ru/maps/?text=%D1%83%D0%BB.%20%D0%91%D0%B5%D1%80%D0%B5%D0%B3%D0%BE%D0%B2%D0%B0%D1%8F%202%D0%91%2C%20%D1%81%D0%B5%D0%BB%D0%BE%20%D0%93%D1%80%D0%B5%D0%BC%D1%8F%D1%87%D0%B8%D0%BD%D1%81%D0%BA%2C%20%D0%9F%D1%80%D0%B8%D0%B1%D0%B0%D0%B9%D0%BA%D0%B0%D0%BB%D1%8C%D1%81%D0%BA%D0%B8%D0%B9%20%D1%80%D0%B0%D0%B9%D0%BE%D0%BD%2C%20%D0%A0%D0%B5%D1%81%D0%BF%D1%83%D0%B1%D0%BB%D0%B8%D0%BA%D0%B0%20%D0%91%D1%83%D1%80%D1%8F%D1%82%D0%B8%D1%8F" target="_blank" rel="noreferrer">Как добраться</a>
            <a href="tel:+79247761161">Контакты</a>
            <a href="mailto:brcbs@bk.ru">Обратная связь</a>
          </div>
        </nav>
      </div>

      <div class="footer-bottom">
        <p>© 2026 Моё Прибайкалье<br />Культурно-туристический центр</p>
      </div>
    </footer>

    <BookingModal />

    <div class="mobile-menu" aria-hidden="true">
      <div class="mobile-menu__overlay" data-menu-close></div>
      <nav class="mobile-menu__panel" aria-label="Мобильное меню">
        <button class="mobile-menu__close" type="button" aria-label="Закрыть меню" data-menu-close>
          <span></span>
          <span></span>
        </button>
        <a href={`${home}#about`} data-menu-close>О месте</a>
        <a href={asset("/services")} data-menu-close>Услуги</a>
        <a href={asset("/menu")} data-menu-close>Кафе</a>
        <a href={asset("/history")} data-menu-close>История</a>
        <a href={asset("/events")} data-menu-close>Афиша</a>
        <a href={asset("/press")} data-menu-close>Пресса о нас</a>
        <a href={`${home}#gallery`} data-menu-close>Галерея</a>
        <a href={`${home}#contacts`} data-menu-close>Контакты</a>
      </nav>
    </div>

    <script src={asset("/scripts/events-feed.js")} defer></script>
    <script>
      const mobileMenu = document.querySelector(".mobile-menu");
      const menuOpenButtons = document.querySelectorAll("[data-menu-open]");
      const menuCloseButtons = document.querySelectorAll("[data-menu-close]");

      const openMobileMenu = () => {
        mobileMenu?.classList.add("is-open");
        mobileMenu?.setAttribute("aria-hidden", "false");
        document.body.classList.add("menu-open");
        menuOpenButtons.forEach((button) => button.setAttribute("aria-expanded", "true"));
      };

      const closeMobileMenu = () => {
        mobileMenu?.classList.remove("is-open");
        mobileMenu?.setAttribute("aria-hidden", "true");
        document.body.classList.remove("menu-open");
        menuOpenButtons.forEach((button) => button.setAttribute("aria-expanded", "false"));
      };

      menuOpenButtons.forEach((button) => button.addEventListener("click", openMobileMenu));
      menuCloseButtons.forEach((button) => button.addEventListener("click", closeMobileMenu));

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeMobileMenu();
        }
      });
    </script>
  </body>
</html>
