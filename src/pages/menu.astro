---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Меню кафе | Моё Прибайкалье</title>
  </head>
  <body>
    <header class="history-page-header menu-page-header">
      <a class="logo" href={home} aria-label="Моё Прибайкалье">
        <span class="logo-image" aria-hidden="true"></span>
      </a>

      <nav class="nav" aria-label="Навигация по сайту">
        <a href={`${home}#about`}>О месте</a>
        <a href={asset("/services")}>Услуги</a>
        <a class="is-active" href={asset("/menu")}>Кафе</a>
        <a href={asset("/history")}>История</a>
        <a href={asset("/events")}>Афиша</a>
        <a href={asset("/press")}>Пресса о нас</a>
        <a href={`${home}#gallery`}>Галерея</a>
        <a href={`${home}#contacts`}>Контакты</a>
      </nav>

      <div class="header-actions">
        <a class="booking-button" href={`${home}#booking`}>Забронировать</a>
        <button class="menu-button" type="button" aria-label="Открыть меню" aria-expanded="false" data-menu-open>
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <main class="cafe-menu-page">
      <section class="cafe-menu-hero">
        <div class="cafe-menu-hero__copy">
          <p class="section-kicker">Питание на базе</p>
          <h1>Меню кафе</h1>
          <p class="cafe-menu-hero__lead">Домашняя кухня из свежих местных продуктов</p>
          <span class="cafe-menu-hero__divider" aria-hidden="true"></span>
          <p class="cafe-menu-hero__text">Мы готовим как дома — из натуральных ингредиентов с Байкальского региона. Сытно, вкусно и по-домашнему.</p>
        </div>

        <figure class="cafe-menu-hero__photo">
          <img src={asset("/images/cafe-menu-hero-food.png")} alt="Домашний суп, салат, хлеб и чай на деревянном столе" />
        </figure>
      </section>

      <section class="cafe-menu-board" id="full-menu">
        <aside class="cafe-menu-sidebar" aria-label="Разделы меню">
          <h2>Меню кафе</h2>
          <nav>
            {menuSections.map((section) => (
              <button class:list={{ "is-active": section.id === "popular" }} type="button" data-menu-filter={section.id}>
                <img src={section.icon} alt="" loading="lazy" />
                <span>{section.title}</span>
              </button>
            ))}
            <button type="button" data-menu-filter="complex">
              <img src={asset("/images/menu-icons/menu-breakfast.png")} alt="" loading="lazy" />
              <span>Комплексное питание</span>
            </button>
            <button type="button" data-menu-filter="banquet">
              <img src={asset("/images/menu-icons/menu-banquet.png")} alt="" loading="lazy" />
              <span>Банкетное</span>
            </button>
          </nav>
          <a class="cafe-menu-sidebar__download" href={asset("/images/menu-moe-pribaikalye.jpg")} target="_blank" rel="noreferrer">Открыть исходное меню</a>
        </aside>

        <div class="cafe-menu-content">
          {menuSections.map((section) => (
            <section class="cafe-menu-section" id={section.id} data-menu-panel={section.id} hidden={section.id !== "popular"}>
              <div class="cafe-menu-section__head">
                <div>
                  <img src={section.icon} alt="" loading="lazy" />
                  <h2>{section.title}</h2>
                </div>
                <span>{section.note}</span>
              </div>
              <div class="cafe-menu-list">
                {section.items.map(([title, text, price]) => (
                  <article>
                    <div>
                      <h3>{title}</h3>
                      <p>{text}</p>
                    </div>
                    <strong>{price}</strong>
                  </article>
                ))}
              </div>
            </section>
          ))}

          <section class="cafe-menu-section cafe-menu-section--plans" id="complex" data-menu-panel="complex" hidden>
            <div class="cafe-menu-section__head">
              <div>
                <img src={asset("/images/menu-icons/menu-complex.png")} alt="" loading="lazy" />
                <h2>Комплексное питание</h2>
              </div>
              <span>3 формата</span>
            </div>
            <div class="cafe-menu-plans">
              {mealPlans.map((plan) => (
                <article>
                  <img src={plan.icon} alt="" loading="lazy" />
                  <strong>{plan.title}</strong>
                  <span>{plan.price}</span>
                  <p>{plan.text}</p>
                </article>
              ))}
            </div>
          </section>

          <section class="cafe-menu-section" id="banquet" data-menu-panel="banquet" hidden>
            <div class="cafe-menu-section__head">
              <div>
                <img src={asset("/images/menu-icons/menu-banquet.png")} alt="" loading="lazy" />
                <h2>Банкетное предложение</h2>
              </div>
              <span>{banquetItems.length} позиций</span>
            </div>
            <div class="cafe-menu-list cafe-menu-list--two">
              {banquetItems.map(([title, text, price]) => (
                <article>
                  <div>
                    <h3>{title}</h3>
                    <p>{text}</p>
                  </div>
                  <strong>{price}</strong>
                </article>
              ))}
            </div>
          </section>
        </div>
      </section>

    </main>

    <div class="mobile-menu" aria-hidden="true">
      <div class="mobile-menu__overlay" data-menu-close></div>
      <nav class="mobile-menu__panel" aria-label="Мобильное меню">
        <button class="mobile-menu__close" type="button" aria-label="Закрыть меню" data-menu-close>
          <span></span>
          <span></span>
        </button>
        <a href={`${home}#about`} data-menu-close>О месте</a>
        <a href={asset("/services")} data-menu-close>Услуги</a>
        <a href={asset("/menu")} data-menu-close>Кафе</a>
        <a href={asset("/history")} data-menu-close>История</a>
        <a href={asset("/events")} data-menu-close>Афиша</a>
        <a href={asset("/press")} data-menu-close>Пресса о нас</a>
        <a href={`${home}#contacts`} data-menu-close>Контакты</a>
        <a class="mobile-menu__booking" href={`${home}#booking`} data-menu-close>Забронировать</a>
      </nav>
    </div>

    <script>
      const mobileMenu = document.querySelector(".mobile-menu");
      const menuOpenButtons = document.querySelectorAll("[data-menu-open]");
      const menuCloseButtons = document.querySelectorAll("[data-menu-close]");

      const openMobileMenu = () => {
        mobileMenu?.classList.add("is-open");
        mobileMenu?.setAttribute("aria-hidden", "false");
        document.body.classList.add("menu-open");
        menuOpenButtons.forEach((button) => button.setAttribute("aria-expanded", "true"));
      };

      const closeMobileMenu = () => {
        mobileMenu?.classList.remove("is-open");
        mobileMenu?.setAttribute("aria-hidden", "true");
        document.body.classList.remove("menu-open");
        menuOpenButtons.forEach((button) => button.setAttribute("aria-expanded", "false"));
      };

      menuOpenButtons.forEach((button) => button.addEventListener("click", openMobileMenu));
      menuCloseButtons.forEach((button) => button.addEventListener("click", closeMobileMenu));
      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") closeMobileMenu();
      });

      const menuFilterButtons = document.querySelectorAll("[data-menu-filter]");
      const menuPanels = document.querySelectorAll("[data-menu-panel]");

      const showMenuPanel = (panelId) => {
        menuFilterButtons.forEach((button) => {
          button.classList.toggle("is-active", button.dataset.menuFilter === panelId);
        });

        menuPanels.forEach((panel) => {
          panel.hidden = panel.dataset.menuPanel !== panelId;
        });
      };

      menuFilterButtons.forEach((button) => {
        button.addEventListener("click", () => showMenuPanel(button.dataset.menuFilter));
      });
    </script>
  </body>
</html>
